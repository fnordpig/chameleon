{
  "$defs": {
    "AuthMethod": {
      "description": "How Chameleon expects the operator to authenticate to the target.",
      "enum": [
        "oauth",
        "api-key",
        "bedrock",
        "vertex",
        "azure"
      ],
      "title": "AuthMethod",
      "type": "string"
    },
    "Authorization": {
      "additionalProperties": false,
      "description": "V0: typed schema only; codecs deferred to follow-on spec (\u00a715.1).",
      "properties": {
        "default_mode": {
          "anyOf": [
            {
              "$ref": "#/$defs/DefaultMode"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "filesystem": {
          "$ref": "#/$defs/FilesystemPolicy"
        },
        "network": {
          "$ref": "#/$defs/NetworkPolicy"
        },
        "allow_patterns": {
          "items": {
            "type": "string"
          },
          "title": "Allow Patterns",
          "type": "array"
        },
        "ask_patterns": {
          "items": {
            "type": "string"
          },
          "title": "Ask Patterns",
          "type": "array"
        },
        "deny_patterns": {
          "items": {
            "type": "string"
          },
          "title": "Deny Patterns",
          "type": "array"
        }
      },
      "title": "Authorization",
      "type": "object"
    },
    "Capabilities": {
      "additionalProperties": false,
      "description": "What tools/MCP/skills/subagents the agent can use.\n\nV0 codecs cover `mcp_servers` only; remaining fields are typed schema\nwith deferred codec implementation.",
      "properties": {
        "mcp_servers": {
          "additionalProperties": {
            "oneOf": [
              {
                "$ref": "#/$defs/McpServerStdio"
              },
              {
                "$ref": "#/$defs/McpServerStreamableHttp"
              }
            ]
          },
          "title": "Mcp Servers",
          "type": "object"
        },
        "skills": {
          "items": {
            "type": "string"
          },
          "title": "Skills",
          "type": "array"
        },
        "subagents": {
          "additionalProperties": {
            "type": "string"
          },
          "description": "Mapping of subagent name to a config file path.",
          "title": "Subagents",
          "type": "object"
        },
        "web_search": {
          "anyOf": [
            {
              "enum": [
                "cached",
                "live",
                "disabled"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Web Search"
        }
      },
      "title": "Capabilities",
      "type": "object"
    },
    "DefaultMode": {
      "enum": [
        "read-only",
        "workspace-write",
        "full-access"
      ],
      "title": "DefaultMode",
      "type": "string"
    },
    "Directives": {
      "additionalProperties": false,
      "description": "Behaviour-shaping configuration.",
      "properties": {
        "system_prompt_file": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Filesystem path to a markdown file used as the agent's system prompt.",
          "title": "System Prompt File"
        },
        "commit_attribution": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Commit Attribution"
        },
        "output_style": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Output Style"
        },
        "language": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Language"
        },
        "personality": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Personality"
        },
        "verbosity": {
          "anyOf": [
            {
              "$ref": "#/$defs/Verbosity"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "show_thinking_summary": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Show Thinking Summary"
        }
      },
      "title": "Directives",
      "type": "object"
    },
    "Environment": {
      "additionalProperties": false,
      "description": "Variables and execution context.\n\nV0 codecs cover `variables` only.",
      "properties": {
        "variables": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Variables",
          "type": "object"
        },
        "inherit": {
          "anyOf": [
            {
              "$ref": "#/$defs/InheritPolicy"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "include_only": {
          "items": {
            "type": "string"
          },
          "title": "Include Only",
          "type": "array"
        },
        "exclude": {
          "items": {
            "type": "string"
          },
          "title": "Exclude",
          "type": "array"
        },
        "additional_directories": {
          "items": {
            "type": "string"
          },
          "title": "Additional Directories",
          "type": "array"
        },
        "respect_gitignore": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Respect Gitignore"
        }
      },
      "title": "Environment",
      "type": "object"
    },
    "FilesystemPolicy": {
      "additionalProperties": false,
      "properties": {
        "allow_read": {
          "items": {
            "type": "string"
          },
          "title": "Allow Read",
          "type": "array"
        },
        "allow_write": {
          "items": {
            "type": "string"
          },
          "title": "Allow Write",
          "type": "array"
        },
        "deny_read": {
          "items": {
            "type": "string"
          },
          "title": "Deny Read",
          "type": "array"
        },
        "deny_write": {
          "items": {
            "type": "string"
          },
          "title": "Deny Write",
          "type": "array"
        }
      },
      "title": "FilesystemPolicy",
      "type": "object"
    },
    "Governance": {
      "additionalProperties": false,
      "properties": {
        "managed": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Managed",
          "type": "object"
        },
        "trust": {
          "$ref": "#/$defs/Trust"
        },
        "updates": {
          "$ref": "#/$defs/Updates"
        },
        "features": {
          "additionalProperties": {
            "type": "boolean"
          },
          "title": "Features",
          "type": "object"
        }
      },
      "title": "Governance",
      "type": "object"
    },
    "History": {
      "additionalProperties": false,
      "properties": {
        "persistence": {
          "anyOf": [
            {
              "$ref": "#/$defs/HistoryPersistence"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "max_bytes": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Max Bytes"
        }
      },
      "title": "History",
      "type": "object"
    },
    "HistoryPersistence": {
      "enum": [
        "save-all",
        "none"
      ],
      "title": "HistoryPersistence",
      "type": "string"
    },
    "Identity": {
      "additionalProperties": false,
      "description": "The identity domain \u2014 composed of target-shared and per-target keys.\n\nAll fields are optional so operators can partially configure the\ndomain. Codecs decide what to do when a field is unset.",
      "properties": {
        "reasoning_effort": {
          "anyOf": [
            {
              "$ref": "#/$defs/ReasoningEffort"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "thinking": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Thinking"
        },
        "service_tier": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Service Tier"
        },
        "context_window": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Context Window"
        },
        "model": {
          "anyOf": [
            {
              "additionalProperties": {
                "type": "string"
              },
              "propertyNames": {
                "$ref": "#/$defs/TargetId"
              },
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Target-specific model identifier. Must be a mapping TargetId -> model name (e.g. {claude: 'claude-sonnet-4-7'}); scalar values are rejected (\u00a77.1).",
          "title": "Model"
        },
        "endpoint": {
          "$ref": "#/$defs/IdentityEndpoint"
        },
        "auth": {
          "$ref": "#/$defs/IdentityAuth"
        }
      },
      "title": "Identity",
      "type": "object"
    },
    "IdentityAuth": {
      "additionalProperties": false,
      "description": "Authentication configuration.",
      "properties": {
        "method": {
          "anyOf": [
            {
              "$ref": "#/$defs/AuthMethod"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "api_key_helper": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Path to an executable that prints an API key on stdout.",
          "title": "Api Key Helper"
        }
      },
      "title": "IdentityAuth",
      "type": "object"
    },
    "IdentityEndpoint": {
      "additionalProperties": false,
      "description": "Per-target endpoint base URL (target-specific by nature).",
      "properties": {
        "base_url": {
          "anyOf": [
            {
              "additionalProperties": {
                "type": "string"
              },
              "propertyNames": {
                "$ref": "#/$defs/TargetId"
              },
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Base Url"
        }
      },
      "title": "IdentityEndpoint",
      "type": "object"
    },
    "InheritPolicy": {
      "enum": [
        "all",
        "core",
        "none"
      ],
      "title": "InheritPolicy",
      "type": "string"
    },
    "Interface": {
      "additionalProperties": false,
