    "ReasoningEffort": {
      "description": "Reasoning effort vocabulary shared by Claude and Codex.",
      "enum": [
        "minimal",
        "low",
        "medium",
        "high",
        "xhigh"
      ],
      "title": "ReasoningEffort",
      "type": "string"
    },
    "TargetId": {
      "description": "Registry-validated target identifier.\n\nConstruction fails if `value` is not in `_TARGET_REGISTRY`. Tests\nregister names via `register_target_id`; production code registers\nvia the targets-registry entry-point discovery path (the\nregistries-and-target-protocol task).",
      "properties": {
        "value": {
          "title": "Value",
          "type": "string"
        }
      },
      "required": [
        "value"
      ],
      "title": "TargetId",
      "type": "object"
    },
