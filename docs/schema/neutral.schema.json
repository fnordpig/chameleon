        },
        "notification_channel": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Notification Channel"
        }
      },
      "title": "Interface",
      "type": "object"
    },
    "JsonValue": {
      "anyOf": [
        {
          "type": "boolean"
        },
        {
          "type": "integer"
        },
        {
          "type": "number"
        },
        {
          "type": "string"
        },
        {
          "items": {
            "$ref": "#/$defs/JsonValue"
          },
          "type": "array"
        },
        {
          "additionalProperties": {
            "$ref": "#/$defs/JsonValue"
          },
          "type": "object"
        },
        {
          "type": "null"
        }
      ]
    },
    "Lifecycle": {
      "additionalProperties": false,
      "description": "V0: typed schema only; codecs deferred.",
      "properties": {
        "hooks": {
          "additionalProperties": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "title": "Hooks",
          "type": "object"
        },
        "history": {
          "$ref": "#/$defs/History"
        },
        "telemetry": {
          "$ref": "#/$defs/Telemetry"
