        },
        "denied_domains": {
          "items": {
            "type": "string"
          },
          "title": "Denied Domains",
          "type": "array"
        },
        "allow_local_binding": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
