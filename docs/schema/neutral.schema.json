    "schema_version": {
      "const": 1,
      "title": "Schema Version",
      "type": "integer"
    },
    "identity": {
      "$ref": "#/$defs/Identity"
    },
    "directives": {
      "$ref": "#/$defs/Directives"
    },
    "capabilities": {
      "$ref": "#/$defs/Capabilities"
    },
    "authorization": {
      "$ref": "#/$defs/Authorization"
    },
    "environment": {
      "$ref": "#/$defs/Environment"
    },
    "lifecycle": {
      "$ref": "#/$defs/Lifecycle"
    },
    "interface": {
      "$ref": "#/$defs/Interface"
    },
    "governance": {
      "$ref": "#/$defs/Governance"
    },
    "profiles": {
      "additionalProperties": {
        "$ref": "#/$defs/Profile"
      },
      "title": "Profiles",
      "type": "object"
    },
